export global I18n {
    public pure function text(key: string) -> string {
        return State.translate(State.language, key);
    }

    public pure function minute_label(value: int) -> string {
        if State.language == "en" { return value + " min"; }
        if State.language == "vi" { return value + " phut"; }
        if State.language == "es" { return value + " min"; }
        if State.language == "ja" { return value + "分"; }
        if State.language == "ar" { return value + " د"; }
        return value + "분";
    }

    public pure function second_label(value: int) -> string {
        if State.language == "en" { return value + " sec"; }
        if State.language == "vi" { return value + " giay"; }
        if State.language == "es" { return value + " s"; }
        if State.language == "ja" { return value + "秒"; }
        if State.language == "ar" { return value + " ث"; }
        return value + "초";
    }

    public pure function melody_label(value: int) -> string {
        if State.language == "en" { return "Melody " + value; }
        if State.language == "vi" { return "Giai dieu " + value; }
        if State.language == "es" { return "Melodia " + value; }
        if State.language == "ja" { return "メロディ " + value; }
        if State.language == "ar" { return "لحن " + value; }
        return "멜로디 " + value;
    }

    public pure function char_count_label(value: int) -> string {
        if State.language == "en" { return "(" + value + " chars)"; }
        if State.language == "vi" { return "(" + value + " ky tu)"; }
        if State.language == "es" { return "(" + value + " car.)"; }
        if State.language == "ja" { return "(" + value + "文字)"; }
        if State.language == "ar" { return "(" + value + " أحرف)"; }
        return "(" + value + "자)";
    }

    public pure function wifi_success_message(ssid: string) -> string {
        if State.language == "en" { return "Connected to " + ssid + " successfully."; }
        if State.language == "vi" { return "Da ket noi thanh cong voi mang " + ssid + "."; }
        if State.language == "es" { return "Conexion correcta con la red " + ssid + "."; }
        if State.language == "ja" { return ssid + " ネットワークに正常に接続されました。"; }
        if State.language == "ar" { return "تم الاتصال بنجاح بالشبكة " + ssid + "."; }
        return ssid + " 네트워크에 성공적으로 연결되었습니다.";
    }

    public pure function wifi_fail_message(ssid: string) -> string {
        if State.language == "en" { return "Failed to connect to " + ssid + "."; }
        if State.language == "vi" { return "Ket noi voi mang " + ssid + " that bai."; }
        if State.language == "es" { return "No se pudo conectar a " + ssid + "."; }
        if State.language == "ja" { return ssid + " ネットワーク接続に失敗しました。"; }
        if State.language == "ar" { return "فشل الاتصال بالشبكة " + ssid + "."; }
        return ssid + " 네트워크 연결에 실패했습니다.";
    }
}

export component InteractiveSlider inherits Rectangle {
    in-out property <float> value: 0.0;
    in property <string> setting-key: "";
    in property <brush> track-color: #374151ff;
    in property <brush> fill-color: #4f39f6ff;
    in property <color> knob-color: #00000000;
    in property <length> track-y: 0px;
    in property <length> track-height: 8px;
    in property <length> knob-size: 0px;
    in property <length> knob-y: 0px;

    background: #00000000;

    function set-value(v: float) {
        if (v < 0) {
            root.value = 0;
        } else if (v > 1) {
            root.value = 1;
        } else {
            root.value = v;
        }
        if root.setting-key != "" {
            State.float-setting-live-changed(root.setting-key, root.value);
        }
    }

    function save-value() {
        if root.setting-key != "" {
            State.save-float-setting(root.setting-key, root.value);
        }
    }

    Rectangle {
        x: 0px; y: root.track-y;
        width: parent.width;
        height: root.track-height;
        background: root.track-color;
        border-radius: 16777200px;
        clip: true;

        Rectangle {
            x: 0px; y: 0px;
            width: parent.width * root.value;
            height: parent.height;
            background: root.fill-color;
            border-radius: 16777200px;
        }
    }

    if root.knob-size > 0px: Rectangle {
        x: (parent.width - root.knob-size) * root.value;
        y: root.knob-y;
        width: root.knob-size;
        height: root.knob-size;
        background: root.knob-color;
        border-radius: 33554400px;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;

        moved => {
            root.set-value(self.mouse-x / parent.width);
        }

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                State.play-touch-sound();
                root.set-value(self.mouse-x / parent.width);
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                root.save-value();
            }
        }
    }
}

export component DialogActionButton inherits Rectangle {
    in property <string> label: "";
    in property <brush> fill: #155dfcff;
    in property <color> label-color: #ffffffff;
    in property <length> label-size: 16px;
    callback clicked();

    private property <bool> armed: false;

    background: root.fill;
    border-radius: 12px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.label-color;
        font-family: "Inter";
        font-size: root.label-size;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        x: -8px;
        y: -8px;
        width: parent.width + 16px;
        height: parent.height + 16px;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                root.armed = true;
            } else if event.kind == PointerEventKind.up {
                if root.armed {
                    root.clicked();
                }
                root.armed = false;
            } else if event.kind == PointerEventKind.cancel {
                root.armed = false;
            }
        }
    }
}

export component SmallStatusDialog inherits Rectangle {
    in property <brush> scrim: #00000099;
    in property <length> panel-y: 154px;
    in property <length> panel-height: 292px;
    in property <image> icon-source;
    in property <color> icon-circle-color: #00a63e33;
    in property <string> title: "";
    in property <string> message1: "";
    in property <string> message2: "";
    in property <color> message1-color: #ffffffb2;
    in property <color> message2-color: #ffffffb2;
    in property <string> button-label: "";
    in property <brush> button-fill: #00a63eff;
    in property <length> button-y: 174px;
    callback confirmed();

    width: 1024px;
    height: 600px;
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.scrim;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { }
        }

        Rectangle {
            x: 322px;
            y: root.panel-y;
            width: 380px;
            height: root.panel-height;
            background: @linear-gradient(225.000deg, #1d293dff 0%, #0f172bff 100%);
            border-radius: 20px;
            border-color: #ffffff1a;
            border-width: 1px;

            Rectangle {
                x: 33px;
                y: 33px;
                width: 314px;
                height: root.panel-height - 66px;
                background: #00000000;

                Rectangle {
                    x: 125px;
                    y: 0px;
                    width: 64px;
                    height: 64px;
                    background: root.icon-circle-color;
                    border-radius: 16777200px;

                    Image {
                        x: 16px;
                        y: 16px;
                        width: 32px;
                        height: 32px;
                        source: root.icon-source;
                        image-fit: contain;
                    }
                }

                Text {
                    x: 0px;
                    y: 84px;
                    width: 314px;
                    height: 33px;
                    text: root.title;
                    color: #ffffffff;
                    font-family: "Inter";
                    font-size: 22px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    x: 0px;
                    y: 125px;
                    width: 314px;
                    height: 21px;
                    text: root.message1;
                    color: root.message1-color;
                    font-family: "Inter";
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                if root.message2 != "": Text {
                    x: 0px;
                    y: 146px;
                    width: 314px;
                    height: 21px;
                    text: root.message2;
                    color: root.message2-color;
                    font-family: "Inter";
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                DialogActionButton {
                    x: 0px;
                    y: root.button-y;
                    width: 314px;
                    height: 52px;
                    label: root.button-label;
                    fill: root.button-fill;
                    clicked => { State.play-touch-sound(); root.confirmed(); }
                }
            }
        }
    }
}

