    if root.mode == "symbols": Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000000;

        TextKey { x: 58px; y: 0px; width: 48px; height: 36px; label: "!"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 112px; y: 0px; width: 48px; height: 36px; label: "@"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 166px; y: 0px; width: 48px; height: 36px; label: "#"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 220px; y: 0px; width: 48px; height: 36px; label: "$"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 274px; y: 0px; width: 48px; height: 36px; label: "%"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 328px; y: 0px; width: 48px; height: 36px; label: "^"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 382px; y: 0px; width: 48px; height: 36px; label: "&"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 436px; y: 0px; width: 48px; height: 36px; label: "*"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 490px; y: 0px; width: 48px; height: 36px; label: "("; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 544px; y: 0px; width: 48px; height: 36px; label: ")"; pressed(value) => { root.key-pressed(value); } }

        TextKey { x: 58px; y: 42px; width: 48px; height: 36px; label: "-"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 112px; y: 42px; width: 48px; height: 36px; label: "_"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 166px; y: 42px; width: 48px; height: 36px; label: "="; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 220px; y: 42px; width: 48px; height: 36px; label: "+"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 274px; y: 42px; width: 48px; height: 36px; label: "["; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 328px; y: 42px; width: 48px; height: 36px; label: "]"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 382px; y: 42px; width: 48px; height: 36px; label: "{"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 436px; y: 42px; width: 48px; height: 36px; label: "}"; pressed(value) => { root.key-pressed(value); } }
        TextKey { x: 490px; y: 42px; width: 48px; height: 36px; label: "|"; pressed(value) => { root.key-pressed(value); } }
