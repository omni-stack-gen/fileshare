            TextKey { x: 166px; y: 84px; width: 48px; height: 36px; label: "/"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 220px; y: 84px; width: 48px; height: 36px; label: "?"; pressed(value) => { root.key-pressed(value); } }
        }

        if root.full-symbols: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000000;
            TextKey { x: 58px; y: 84px; width: 48px; height: 36px; label: ";"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 112px; y: 84px; width: 48px; height: 36px; label: ":"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 166px; y: 84px; width: 48px; height: 36px; label: "'"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 220px; y: 84px; width: 48px; height: 36px; label: "\""; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 274px; y: 84px; width: 48px; height: 36px; label: ","; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 328px; y: 84px; width: 48px; height: 36px; label: "."; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 382px; y: 84px; width: 48px; height: 36px; label: "<"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 436px; y: 84px; width: 48px; height: 36px; label: ">"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 490px; y: 84px; width: 48px; height: 36px; label: "/"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 544px; y: 84px; width: 48px; height: 36px; label: "?"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 193px; y: 126px; width: 48px; height: 36px; label: "~"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 247px; y: 126px; width: 48px; height: 36px; label: "`"; pressed(value) => { root.key-pressed(value); } }
            TextKey { x: 301px; y: 126px; width: 156px; height: 36px; label: I18n.text("space"); value: " "; pressed(value) => { root.key-pressed(value); } }
        }

        ModeButton { x: 253px; y: 172px; width: 56px; height: 36px; label: "ABC"; selected: true; clicked => { State.play-touch-sound(); root.mode-changed("lower"); } }
        ModeButton { x: 315px; y: 172px; width: 82px; height: 36px; label: I18n.text("clear"); clicked => { State.play-touch-sound(); root.clear-pressed(); } }
    }

    if root.disabled: TouchArea {
        width: parent.width;
        height: parent.height;
    }
}
