import { State, I18n } from "shared.slint";

component TextKey inherits Rectangle {
    in property <string> label: "";
    in property <string> value: label;
    callback pressed(string);

    background: touch.pressed ? #155dfcff : #ffffff1a;
    border-radius: 8px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #ffffffff;
        font-family: "Inter";
        font-size: 14px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { State.play-touch-sound(); root.pressed(root.value); }
    }
}

component ModeButton inherits Rectangle {
    in property <string> label: "";
    in property <bool> selected: false;
    callback clicked();

    background: root.selected || touch.pressed ? #155dfcff : #ffffff1a;
    border-radius: 8px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #ffffffff;
        font-family: "Inter";
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { State.play-touch-sound(); root.clicked(); }
    }
}

export component FullKeyboardPanel inherits Rectangle {
    in property <string> mode: "lower";
    in property <bool> full-symbols: false;
    in property <bool> disabled: false;
