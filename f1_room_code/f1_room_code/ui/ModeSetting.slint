                x: 804px;
                y: 304px;
                width: 140px;
                height: 180px;
                second-unit: true;
                selected-value: State.door-open-seconds;
                picked(value) => {
                    root.pick-value("mode-door-open", value);
                }
            }
            if State.active-picker == "mode-call-timeout": CallTimeoutPickerPopup {
                x: 804px;
                y: 388px;
                width: 140px;
                height: 108px;
