import { State, I18n } from "shared.slint";

component PickerPopup inherits Rectangle {
    in property <bool> second-unit: false;
    in property <int> selected-value: 1;
    callback picked(int);

    background: #2d394cff;
    border-radius: 12px;
    border-width: 1px;
    border-color: #ffffff14;
    clip: true;

    picker-scroll := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: 5 * 36px;

        for value[index] in [1, 2, 3, 4, 5]: Rectangle {
            x: 0px;
            y: 36px * index;
            width: parent.width;
            height: 36px;
            background: value == root.selected-value ? #155dfc66 : #00000000;

            Text {
                x: 16px;
                y: 8px;
                width: parent.width - 32px;
                height: 20px;
                text: root.second-unit ? I18n.second_label(value) : I18n.minute_label(value);
                color: value == root.selected-value ? #ffffffff : #ffffffcc;
                font-family: "Inter";
                font-size: 14px;
                font-weight: value == root.selected-value ? 500 : 400;
                vertical-alignment: center;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { State.play-touch-sound();
                    root.picked(value);
                }
            }
        }
    }
}

component CallTimeoutPickerPopup inherits Rectangle {
    in property <int> selected-value: 30;
    callback picked(int);

    background: #2d394cff;
    border-radius: 12px;
    border-width: 1px;
    border-color: #ffffff14;
    clip: true;

    for value[index] in [30, 60, 90]: Rectangle {
        x: 0px;
        y: 36px * index;
        width: parent.width;
        height: 36px;
        background: value == root.selected-value ? #155dfc66 : #00000000;

        Text {
            x: 16px;
            y: 8px;
            width: parent.width - 32px;
            height: 20px;
            text: I18n.second_label(value);
            color: value == root.selected-value ? #ffffffff : #ffffffcc;
            font-family: "Inter";
            font-size: 14px;
            font-weight: value == root.selected-value ? 500 : 400;
            vertical-alignment: center;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { State.play-touch-sound();
                root.picked(value);
            }
        }
    }
}

export component ModeSetting inherits Rectangle {
    width: 1024px;
    height: 600px;
    clip: true;
    background: #ffffffff;
    function toggle-picker(name: string) {
        State.active-picker = State.active-picker == name ? "" : name;
    }

    function pick-value(name: string, value: int) {
        if name == "mode-absent" {
            State.absent-mode-minutes = value;
            State.absent-mode-time = I18n.minute_label(value);
            State.save-int-setting("mode.absent_timeout_min", value);
        } else if name == "mode-communication" {
            State.communication-minutes = value;
            State.communication-time = I18n.minute_label(value);
            State.save-int-setting("mode.communication_timeout_min", value);
        } else if name == "mode-call-timeout" {
            State.call-timeout-seconds = value;
            State.call-timeout-value = I18n.second_label(value);
            State.save-int-setting("mode.call_ring_timeout_sec", value);
        } else if name == "mode-door-open" {
            State.door-open-seconds = value;
            State.second-level-value = I18n.second_label(value);
            State.save-int-setting("mode.door_open_duration_sec", value);
        }
        State.active-picker = "";
    }

    Rectangle {
        x: 0px; y: 0px;
        width: 1024px;
        height: 600px;
        background: #ffffffff;
