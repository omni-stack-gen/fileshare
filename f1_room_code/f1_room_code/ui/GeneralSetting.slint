            if State.active-picker != "": Rectangle {
                x: 0px; y: 0px;
                width: 1024px;
                height: 600px;
                background: #00000000;

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { State.play-touch-sound();
                        State.active-picker = "";
                    }
                }
            }
            if State.active-picker == "general-hour": PickerPopup {
                x: 218.719px; y: 188px;
                width: 357.641px;
                height: 224px;
                options: root.hour-options;
                selected-value: root.draft-general-hour;
                picked(value) => {
                    root.pick-value("general-hour", value);
                }
            }
            if State.active-picker == "general-minute": PickerPopup {
                x: 586.359px; y: 188px;
                width: 357.641px;
                height: 224px;
                options: root.minute-options;
                selected-value: root.draft-general-minute;
                picked(value) => {
                    root.pick-value("general-minute", value);
                }
            }
            if State.active-picker == "general-year": PickerPopup {
                x: 80px; y: 312px;
                width: 281.328px;
                height: 224px;
                options: root.year-options;
                selected-value: root.draft-general-year;
                picked(value) => {
                    root.pick-value("general-year", value);
                }
            }
            if State.active-picker == "general-month": PickerPopup {
                x: 371.328px; y: 312px;
                width: 281.344px;
                height: 224px;
                options: root.month-options;
                selected-value: root.draft-general-month;
                picked(value) => {
                    root.pick-value("general-month", value);
                }
            }
            if State.active-picker == "general-day": PickerPopup {
                x: 662.672px; y: 312px;
                width: 281.328px;
                height: 224px;
                options: root.day-options;
                selected-value: root.draft-general-day;
                picked(value) => {
                    root.pick-value("general-day", value);
                }
            }
            Rectangle {
                x: 60px; y: 517px;
                width: 904px;
                height: 59px;
                background: #00000000;
                Rectangle {
                    x: 388.719px; y: 8px;
                    width: 126.547px;
                    height: 51px;
                    background: @linear-gradient(270.000deg, #155dfcff 0%, #1447e6ff 100%);
                    border-radius: 16px;
                    Text {
                        x: 0px; y: 12px;
                        width: parent.width;
                        text: root.tr("save");
                        color: #ffffffff;
                        font-family: "Inter";
                        font-size: 18px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }
                    TouchArea { width: parent.width; height: parent.height; clicked => { State.play-touch-sound(); root.save-all(); } }
                }
            }
        }
    }
}
