import { State, I18n } from "shared.slint";
import { FullKeyboardPanel } from "FullKeyboardPanel.slint";

component ActionButton inherits Rectangle {
    in property <string> label: "";
    in property <brush> bg: #ffffff1a;
    in property <color> fg: #ffffffff;
    in property <bool> sound-enabled: !State.wifi-dialog-locked;
    callback clicked;

    background: root.bg;
    border-radius: 12px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.fg;
        font-family: "Inter";
        font-size: 15px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if root.sound-enabled {
                State.play-touch-sound();
            }
            if !State.wifi-dialog-locked {
                root.clicked();
            }
        }
    }
}

export component WifiPasswordDialog inherits Rectangle {
    width: 1024px;
    height: 600px;
    background: #000000cc;

    in property <string> effective-mode: State.active-overlay == "FmsBT" ? "symbols" : (State.active-overlay == "xMjyH" ? "upper" : (State.active-overlay == "jbQzr" ? "lower" : State.keyboard-mode));

    function clear-password() {
        State.wifi-password = "";
        State.wifi-password-mask = "";
        State.wifi-password-length = 0;
        State.password-visible = false;
    }

    function close-keyboard() {
        if State.wifi-dialog-locked {
            return;
        }
        State.active-overlay = "";
        State.keyboard-target = "";
        State.keyboard-mode = "lower";
        root.clear-password();
    }

    function set-mode(mode: string) {
        State.keyboard-mode = mode;
        State.active-overlay = "wifi-password";
    }

    function connect-wifi() {
        if State.wifi-target-ssid != "" {
            State.wifi-dialog-locked = true;
            State.connect-wifi(State.wifi-target-ssid, State.wifi-password);
        }
    }

    Rectangle {
        x: 162px; y: 76px;
        width: 700px;
        height: 448px;
        background: #172238ff;
        border-radius: 20px;
        border-color: #ffffff1a;
        border-width: 1px;
        clip: true;

        Rectangle {
            x: 1px; y: 1px;
            width: 698px;
            height: 65px;
            background: #00000000;
            border-color: #ffffff1a;
            border-width: 1px;

            Image {
                x: 24px; y: 22.5px;
                width: 20px;
                height: 20px;
                source: @image-url("../assets/images/5HbN6.png");
                image-fit: contain;
            }

            Text {
                x: 56px; y: 23.5px;
                width: 120px;
                height: 20px;
                text: I18n.text("enter_password");
                color: #ffffff99;
                font-family: "Inter";
                font-size: 12px;
                vertical-alignment: center;
            }

            Image {
                x: 648px; y: 22.5px;
                width: 20px;
                height: 20px;
                source: @image-url("../assets/images/9MMaM.png");
                image-fit: contain;
            }

            TouchArea {
                x: 642px; y: 16.5px;
                width: 32px;
                height: 32px;
                clicked => { State.play-touch-sound();
                    root.close-keyboard();
                }
            }
        }

        Rectangle {
            x: 25px; y: 86px;
            width: 650px;
            height: 48.5px;
            background: #202c3eff;
            border-radius: 12px;
            border-color: #ffffff1a;
            border-width: 1px;
            clip: true;

            Text {
                x: 16px; y: 12px;
                width: 574px;
                height: 24px;
                text: State.wifi-password == "" ? I18n.text("enter_password_placeholder") : (State.password-visible ? State.wifi-password : State.wifi-password-mask);
                color: State.wifi-password == "" ? #ffffff66 : #ffffffff;
                font-family: "Inter";
                font-size: 15px;
                vertical-alignment: center;
            }

            Image {
                x: 613px; y: 15.25px;
                width: 18px;
                height: 18px;
                source: State.password-visible ? @image-url("../assets/images/B95EY.png") : @image-url("../assets/images/XYnkN.png");
                image-fit: contain;
            }

            TouchArea {
                x: 606px; y: 8.25px;
                width: 32px;
                height: 32px;
                clicked => {
                    if !State.wifi-dialog-locked {
                        State.play-touch-sound();
                        State.password-visible = !State.password-visible;
                    }
                }
            }
        }

        FullKeyboardPanel {
            x: 25px; y: 150.5px;
            width: 650px;
            height: 208px;
            mode: root.effective-mode;
            full-symbols: true;
            disabled: State.wifi-dialog-locked;
            key-pressed(value) => {
                State.wifi-password += value;
                State.wifi-password-mask += "*";
                State.wifi-password-length += 1;
            }
            mode-changed(value) => { root.set-mode(value); }
            clear-pressed => { root.clear-password(); }
        }

        ActionButton {
            x: 25px; y: 378.5px;
            width: 319px;
            height: 48.5px;
            label: I18n.text("cancel");
            clicked => {
                root.close-keyboard();
            }
        }

        ActionButton {
            x: 356px; y: 378.5px;
            width: 319px;
            height: 48.5px;
            label: I18n.text("connect");
            bg: (State.wifi-password == "" && !State.wifi-target-open) || State.wifi-dialog-locked ? #ffffff0d : #155dfcff;
            fg: (State.wifi-password == "" && !State.wifi-target-open) || State.wifi-dialog-locked ? #ffffff4d : #ffffffff;
            sound-enabled: !State.wifi-dialog-locked && (State.wifi-target-open || State.wifi-password != "");
            clicked => {
                if !State.wifi-dialog-locked && (State.wifi-target-open || State.wifi-password != "") {
                    root.connect-wifi();
                }
            }
        }
    }
}
