import { State, I18n, InteractiveSlider } from "shared.slint";
import { ButtonEffectGuhoF } from "ButtonEffectGuhoF.slint";

export component GuardPhoneCall inherits Rectangle {
    width: 1024px;
    height: 600px;
    clip: true;
    background: #ffffffff;
    property <bool> manager-outgoing-ringing: State.call-session-state == "ringing" && State.call-peer-id == "manager";
    property <bool> call-button-enabled: !State.guard-call-effect-active && (State.call-session-state == "idle" || (State.call-session-state == "ringing" && !root.manager-outgoing-ringing));
    Rectangle {
        x: 0px; y: 0px;
        width: 1024px;
        height: 600px;
        background: #030712ff;
        Rectangle {
            x: 0px; y: 0px;
            width: 1024px;
            height: 600px;
            background: @linear-gradient(225.000deg, #101828ff 0%, #1e2939ff 50%, #101828ff 100%);
            clip: true;
            Rectangle {
                x: 0px; y: 0px;
                width: 1024px;
                height: 50px;
                background: #00000000;
                Text {
                    x: 26px; y: 11px;
                    text: I18n.text("guard_room_call");
                    color: #ffffffff;
                    font-family: "Inter";
                    font-size: 18px;
                    font-weight: 500;
                }
                Rectangle {
                    x: 964px; y: 7px;
                    width: 36px;
                    height: 36px;
                    background: #36415380;
                    border-radius: 14px;
                    Image {
                        x: 8px; y: 8px;
                        width: 20px;
                        height: 20px;
                        source: @image-url("../assets/images/6o4cI.png");
                        image-fit: contain;
                    }
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            State.play-touch-sound();
                            if State.call-session-state == "idle" {
                                State.current-page = "LCvek";
                                State.pressed-effect = "";
                                State.call-effect-locked = false;
                                State.guard-call-effect-active = false;
                            } else if State.call-session-state == "ringing" {
                                State.call-reject();
                            } else {
                                State.call-hangup();
                            }
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 50px;
                width: 1024px;
                height: 420px;
                background: #00000000;
                Rectangle {
                    x: 24px; y: 0px;
                    width: 850px;
                    height: 420px;
                    background: #1e2939ff;
                    border-radius: 16px;
                    clip: true;
                    Rectangle {
                        x: 290px; y: 73px;
                        width: 270px;
                        height: 273px;
                        background: #00000000;
                        clip: true;
                        opacity: 0.7000;
                        Image {
                            x: 0px; y: 0px;
                            width: parent.width;
                            height: parent.height;
                            source: @image-url("../assets/images/Group_4.png");
                            image-fit: contain;
                        }
                    }
                    Text {
                        x: 248px; y: 346px;
                        width: 353px;
                        height: 29px;
                        text: I18n.text("guard_calling");
                        color: #ffffffff;
                        font-family: "Inter";
                        font-size: 24px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }
                }
                Rectangle {
                    x: 890px; y: 0px;
                    width: 110px;
                    height: 420px;
                    background: #00000000;
                    Rectangle {
                        x: 0px; y: 0px;
                        width: 110px;
                        height: 252px;
                        background: @linear-gradient(225.000deg, #4f39f6ff 0%, #9810faff 100%);
                        border-radius: 16px;
                        Image {
                            x: 39px; y: 96px;
                            width: 32px;
                            height: 32px;
                            source: @image-url("../assets/images/Es0ay.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 42.887px; y: 136px;
                            width: 24.227px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("call");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        TouchArea {
                            enabled: root.call-button-enabled;
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                State.play-touch-sound();
                                if State.call-session-state == "ringing" && !root.manager-outgoing-ringing {
                                    State.guard-call-effect-active = true;
                                    State.call-accept();
                                } else if State.call-session-state == "idle" {
                                    State.guard-call-effect-active = false;
                                    State.call-start("aiot:manager");
                                }
                            }
                        }
                    }
                    Rectangle {
                        x: 0px; y: 264px;
                        width: 110px;
                        height: 156px;
                        background: @linear-gradient(225.000deg, #314158ff 0%, #1d293dff 100%);
                        border-radius: 16px;
                        Image {
                            x: 39px; y: 48px;
                            width: 32px;
                            height: 32px;
                            source: @image-url("../assets/images/IugYF.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 42.887px; y: 88px;
                            width: 24.227px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("end");
                                color: #ff0505ff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { State.play-touch-sound();
                                if State.call-session-state == "idle" {
                                    State.current-page = "LCvek";
                                    State.pressed-effect = "";
                                    State.call-effect-locked = false;
                                    State.guard-call-effect-active = false;
                                } else if State.call-session-state == "ringing" {
                                    State.call-reject();
                                } else {
                                    State.call-hangup();
                                }
                            }
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 470px;
                width: 1024px;
                height: 130px;
                background: #00000000;
                Rectangle {
                    x: 24px; y: 43px;
                    width: 976px;
                    height: 44px;
                    background: #1e293999;
                    border-radius: 14px;
                    Rectangle {
                        x: 24px; y: 12px;
                        width: 422.5px;
                        height: 20px;
                        background: #00000000;
                        Image {
                            x: 0px; y: 0px;
                            width: 20px;
                            height: 20px;
                            source: @image-url("../assets/images/WrzoC.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 32px; y: 0px;
                            width: 72px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                x: 0px; y: 0px;
                                width: 80px;
                                height: parent.height;
                                text: I18n.text("brightness");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                        InteractiveSlider {
                            x: 112px; y: 0px;
                            width: 266.5px;
                            height: 20px;
                            track-y: 6px;
                            track-height: 8px;
                            setting-key: "call.guard.brightness";
                            value <=> State.guard-brightness-value;
                        }
                        Rectangle {
                            x: parent.width - 32px; y: 0px;
                            width: 32px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: round(State.guard-brightness-value * 100) + "%";
                                color: #d1d5dcff;
                                font-family: "Inter";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        x: 136px + 266.5px * State.guard-brightness-value - 17.5px; y: 4px;
                        width: 35px;
                        height: 35px;
                        background: #00000000;
                        clip: true;
                        Image {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            source: @image-url("../images/image-import.png");
                            image-fit: cover;
                        }
                    }
                    Rectangle {
                        x: 529.5px; y: 12px;
                        width: 422.5px;
                        height: 20px;
                        background: #00000000;
                        Image {
                            x: 0px; y: 0px;
                            width: 20px;
                            height: 20px;
                            source: @image-url("../assets/images/3xNCy.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 32px; y: 0px;
                            width: 72px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                x: 0px; y: 0px;
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("volume");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                        InteractiveSlider {
                            x: 112px; y: 0px;
                            width: 266.5px;
                            height: 20px;
                            track-y: 6px;
                            track-height: 8px;
                            setting-key: "call.guard.volume";
                            value <=> State.guard-volume-value;
                        }
                        Rectangle {
                            x: parent.width - 32px; y: 0px;
                            width: 32px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: round(State.guard-volume-value * 100) + "%";
                                color: #d1d5dcff;
                                font-family: "Inter";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        x: 641.5px + 266.5px * State.guard-volume-value - 17.5px; y: 4px;
                        width: 35px;
                        height: 35px;
                        background: #00000000;
                        clip: true;
                        Image {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            source: @image-url("../images/image-import.png");
                            image-fit: cover;
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 600px;
                width: 2731px;
                height: 4096px;
                background: #00000000;
                clip: true;
            }
        }
    }
    if State.guard-call-effect-active: ButtonEffectGuhoF { x: 890px; y: 50px; }
}
