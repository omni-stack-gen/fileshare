import { State, I18n, InteractiveSlider } from "shared.slint";

export component LobbyPhoneCall inherits Rectangle {
    width: 1024px;
    height: 600px;
    clip: true;
    background: #00000000;
    Rectangle {
        x: 0px; y: 0px;
        width: 1024px;
        height: 50px;
        background: @linear-gradient(225.000deg, #101828ff 0%, #1e2939ff 50%, #101828ff 100%);
    }
    Rectangle {
        x: 0px; y: 50px;
        width: 24px;
        height: 420px;
        background: @linear-gradient(225.000deg, #101828ff 0%, #1e2939ff 50%, #101828ff 100%);
    }
    Rectangle {
        x: 874px; y: 50px;
        width: 150px;
        height: 420px;
        background: @linear-gradient(225.000deg, #101828ff 0%, #1e2939ff 50%, #101828ff 100%);
    }
    Rectangle {
        x: 0px; y: 470px;
        width: 1024px;
        height: 130px;
        background: @linear-gradient(225.000deg, #101828ff 0%, #1e2939ff 50%, #101828ff 100%);
    }
    Rectangle {
        x: 0px; y: 0px;
        width: 1024px;
        height: 600px;
        background: #00000000;
        clip: true;
            Rectangle {
                x: 0px; y: 0px;
                width: 1024px;
                height: 50px;
                background: #00000000;
                Text {
                    x: 26px; y: 11px;
                    text: I18n.text("lobby_call_title");
                    color: #ffffffff;
                    font-family: "Inter";
                    font-size: 18px;
                    font-weight: 500;
                }
                Rectangle {
                    x: 964px; y: 7px;
                    width: 36px;
                    height: 36px;
                    background: #36415380;
                    border-radius: 14px;
                    Image {
                        x: 8px; y: 8px;
                        width: 20px;
                        height: 20px;
                        source: @image-url("../assets/images/6o4cI.png");
                        image-fit: contain;
                    }
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            State.play-touch-sound();
                            if State.call-session-state == "idle" {
                                State.current-page = "LCvek";
                                State.pressed-effect = "";
                                State.call-effect-locked = false;
                                State.lobby-call-effect-active = false;
                                State.lobby-open-effect-active = false;
                                State.lobby-end-effect-active = false;
                            } else if State.call-session-state == "ringing" {
                                State.call-reject();
                            } else {
                                State.call-hangup();
                            }
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 50px;
                width: 1024px;
                height: 420px;
                background: #00000000;
                Rectangle {
                    x: 24px; y: 0px;
                    width: 850px;
                    height: 420px;
                    background: #00000000;
                    border-radius: 16px;
                    clip: true;
                    Rectangle {
                        x: 0px; y: -58px;
                        width: 850px;
                        height: 536px;
                        background: #00000000;
                        clip: true;
                    }
                    if State.call-snapshot-visible: Image {
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        source: State.call-snapshot-image;
                        image-fit: cover;
                    }
                }
                Rectangle {
                    x: 890px; y: 0px;
                    width: 110px;
                    height: 420px;
                    background: #00000000;
                    Rectangle {
                        x: 0px; y: 0px;
                        width: 110px;
                        height: 132px;
                        background: State.lobby-call-effect-active ? #1dba25ff : @linear-gradient(225.000deg, #4f39f6ff 0%, #9810faff 100%);
                        border-radius: 16px;
                        Image {
                            x: 39px; y: 36px;
                            width: 32px;
                            height: 32px;
                            source: @image-url("../assets/images/Es0ay.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 42.887px; y: 76px;
                            width: 24.227px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("call");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        call-touch := TouchArea {
                            enabled: !State.lobby-call-effect-active;
                            width: parent.width;
                            height: parent.height;
                            clicked => { State.play-touch-sound();
                                State.lobby-call-effect-active = true;
                                State.call-accept();
                            }
                        }
                    }
                    Rectangle {
                        x: 0px; y: 144px;
                        width: 110px;
                        height: 132px;
                        background: open-touch.pressed ? #d16f29ff : @linear-gradient(225.000deg, #4f39f6ff 0%, #432dd7ff 100%);
                        border-radius: 16px;
                        Image {
                            x: 39px; y: 36px;
                            width: 32px;
                            height: 32px;
                            source: @image-url("../assets/images/9ye3C.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 15px; y: 76px;
                            width: 80px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                x: 0px; y: 0px;
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("door_open");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        open-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { State.play-touch-sound(); State.call-open-door(); }
                        }
                    }
                    Rectangle {
                        x: 0px; y: 288px;
                        width: 110px;
                        height: 132px;
                        background: end-touch.pressed
                            ? #bebbb9ff
                            : @linear-gradient(225.000deg, #314158ff 0%, #1d293dff 100%);
                        border-radius: 16px;
                        Image {
                            x: 39px; y: 36px;
                            width: 32px;
                            height: 32px;
                            source: @image-url("../assets/images/IugYF.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 42.887px; y: 76px;
                            width: 24.227px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("end");
                                color: #ff0505ff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        end-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { State.play-touch-sound();
                                if State.call-session-state == "ringing" { State.call-reject(); } else { State.call-hangup(); }
                            }
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 470px;
                width: 1024px;
                height: 130px;
                background: #00000000;
                Rectangle {
                    x: 24px; y: 43px;
                    width: 976px;
                    height: 44px;
                    background: #1e293999;
                    border-radius: 14px;
                    Rectangle {
                        x: 24px; y: 12px;
                        width: 422.5px;
                        height: 20px;
                        background: #00000000;
                        Image {
                            x: 0px; y: 0px;
                            width: 20px;
                            height: 20px;
                            source: @image-url("../assets/images/WrzoC.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 32px; y: 0px;
                            width: 72px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                x: 0px; y: 0px;
                                width: 80px;
                                height: parent.height;
                                text: I18n.text("brightness");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                        InteractiveSlider {
                            x: 112px; y: 0px;
                            width: 266.5px;
                            height: 20px;
                            track-y: 6px;
                            track-height: 8px;
                            setting-key: "call.lobby.brightness";
                            value <=> State.lobby-brightness-value;
                        }
                        Rectangle {
                            x: 390.5px; y: 0px;
                            width: 32px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: round(State.lobby-brightness-value * 100) + "%";
                                color: #d1d5dcff;
                                font-family: "Inter";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        x: 136px + 266.5px * State.lobby-brightness-value - 17.5px; y: 4px;
                        width: 35px;
                        height: 35px;
                        background: #00000000;
                        clip: true;
                        Image {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            source: @image-url("../images/image-import.png");
                            image-fit: cover;
                        }
                    }
                    Rectangle {
                        x: 529.5px; y: 12px;
                        width: 422.5px;
                        height: 20px;
                        background: #00000000;
                        Image {
                            x: 0px; y: 0px;
                            width: 20px;
                            height: 20px;
                            source: @image-url("../assets/images/3xNCy.png");
                            image-fit: contain;
                        }
                        Rectangle {
                            x: 32px; y: 0px;
                            width: 72px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                x: 0px; y: 0px;
                                width: parent.width;
                                height: parent.height;
                                text: I18n.text("volume");
                                color: #ffffffff;
                                font-family: "Inter";
                                font-size: 14px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                        InteractiveSlider {
                            x: 112px; y: 0px;
                            width: 266.5px;
                            height: 20px;
                            track-y: 6px;
                            track-height: 8px;
                            setting-key: "call.lobby.volume";
                            value <=> State.lobby-volume-value;
                        }
                        Rectangle {
                            x: 390.5px; y: 0px;
                            width: 40px;
                            height: 20px;
                            background: #00000000;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: round(State.lobby-volume-value * 100) + "%";
                                color: #d1d5dcff;
                                font-family: "Inter";
                                font-size: 14px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        x: 641.5px + 266.5px * State.lobby-volume-value - 17.5px; y: 4px;
                        width: 35px;
                        height: 35px;
                        background: #00000000;
                        clip: true;
                        Image {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            source: @image-url("../images/image-import.png");
                            image-fit: cover;
                        }
                    }
                }
            }
            Rectangle {
                x: 0px; y: 600px;
                width: 2731px;
                height: 4096px;
                background: #00000000;
                clip: true;
            }
    }
}
